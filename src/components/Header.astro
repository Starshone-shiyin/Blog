---
import { withBase } from '@/lib/blog';

const navItems = [
  { href: '/', label: '首页' },
  { href: '/posts/', label: '文章' },
  { href: '/tags/', label: '标签' },
  { href: '/about/', label: '关于' },
];
---

<header class="site-header">
  <a class="brand" href={withBase('/')} aria-label="回到首页">
    <img class="brand-avatar" src={withBase('/images/avatar.jpg')} alt="" width="34" height="34" />
    <span>Blog</span>
  </a>
  <nav class="site-nav" aria-label="主导航">
    {
      navItems.map((item) => (
        <a href={withBase(item.href)} class:list={{ active: Astro.url.pathname === withBase(item.href) }}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

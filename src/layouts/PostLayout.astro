---
import BaseLayout from './BaseLayout.astro';
import { render } from 'astro:content';
import { formatDate, tagPath, withBase } from '@/lib/blog';
import type { BlogPost } from '@/lib/blog';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <article class="article-shell">
    <header class="article-header">
      <a class="back-link" href={withBase('/posts/')}>← 文章列表</a>
      <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row" aria-label="标签">
        {post.data.tags.map((tag) => <a href={withBase(tagPath(tag))}>{tag}</a>)}
      </div>
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

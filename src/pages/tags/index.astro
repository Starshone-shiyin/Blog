---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getAllTags, tagPath, withBase } from '@/lib/blog';

const tags = await getAllTags();
---

<BaseLayout title="标签 | Blog" description="按标签浏览文章。">
  <section class="page-heading">
    <p class="eyebrow">Tags</p>
    <h1>标签</h1>
    <p>用几个关键词，给不断变化的兴趣留下一点线索。</p>
  </section>
  <div class="tag-cloud large">
    {tags.map((tag) => <a href={withBase(tagPath(tag.name))}>#{tag.name}<span>{tag.count}</span></a>)}
  </div>
</BaseLayout>
